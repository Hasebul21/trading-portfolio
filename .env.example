NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) or new publishable key (sb_publishable_...) from Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: broker commission as decimal fraction of gross (qty × price). Default 0.004 = 0.4%.
# NEXT_PUBLIC_TRADE_COMMISSION_RATE=0.004

# Optional: DSE portfolio data (defaults: dsebd.org LSP + displayCompany.php)
# DSE_LSP_URL=https://dsebd.org/latest_share_price_scroll_l.php
# DSE_COMPANY_URL_BASE=https://dsebd.org/displayCompany.php
# Optional: trading-code list (plain quotes.txt). Default tries dsebd.org + www + com.bd.
# DSE_QUOTES_TXT_URL=https://dsebd.org/datafile/quotes.txt

# Email reports (manual + monthly). Uses SMTP via nodemailer.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com
#
# Recipient for monthly/manual portfolio reports.
# Defaults to hasebulhassan21@gmail.com if omitted.
# PORTFOLIO_REPORT_RECIPIENT=hasebulhassan21@gmail.com
#
# Monthly cron auth secret (for /api/portfolio-report).
# If deploying on Vercel, setting CRON_SECRET also works.
# PORTFOLIO_REPORT_CRON_SECRET=change-me
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
