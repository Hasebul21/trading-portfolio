NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy anon JWT (eyJ...) or new publishable key (sb_publishable_...) from Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: broker commission as decimal fraction of gross (qty × price). Default 0.004 = 0.4%.
# NEXT_PUBLIC_TRADE_COMMISSION_RATE=0.004

# Optional: DSE portfolio data (defaults: dsebd.org LSP + displayCompany.php)
# DSE_LSP_URL=https://dsebd.org/latest_share_price_scroll_l.php
# DSE_COMPANY_URL_BASE=https://dsebd.org/displayCompany.php
# Optional: trading-code list (plain quotes.txt). Default tries dsebd.org + www + com.bd.
# DSE_QUOTES_TXT_URL=https://dsebd.org/datafile/quotes.txt

# ─────────────────────────────────────────────────────────────────────────
# Daily portfolio email — fires every day at 17:00 Asia/Dhaka (= 11:00 UTC,
# scheduled in vercel.json as `0 11 * * *`).
#
# All FIVE of these vars must be set in Vercel → Settings → Environment
# Variables (Production scope) for the cron to actually send mail. A miss
# of any one will surface in the cron's response body and Vercel logs.
# ─────────────────────────────────────────────────────────────────────────
#
# Resend API key (https://resend.com → API Keys → Create).
# RESEND_API_KEY=re_xxxxxxxxx
#
# Verified sender. While Resend is unverified, only your own account email
# can be the recipient. Once you verify a domain, set this to a sender on
# that domain.
# RESEND_FROM=Portfolio <onboarding@resend.dev>
#
# Where to deliver the daily email. MUST match an existing user in
# Supabase auth.users (case-insensitive) — that's how we know which
# user's portfolio to compute. Defaults to hasebulhassan21@gmail.com.
# PORTFOLIO_REPORT_RECIPIENT=hasebulhassan21@gmail.com
#
# Cron auth secret. Vercel sends this in the Authorization header.
# CRON_SECRET also works as a fallback.
# PORTFOLIO_REPORT_CRON_SECRET=change-me
#
# Supabase service-role key — required because the cron runs as a system
# job, not as the logged-in user. (Project Settings → API → service_role.)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
